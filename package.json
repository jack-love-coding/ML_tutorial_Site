{
  "name": "ml-tutorial-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:pages": "vue-tsc -b && vite build --mode github-pages",
    "preview": "vite preview",
    "test": "node --test tests/*.test.*",
    "security:audit": "npm audit --audit-level=moderate --registry=https://registry.npmjs.org"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "katex": "^0.16.44",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "sanitize-html": "^2.17.4",
    "three": "^0.184.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.11",
    "vue-tsc": "^3.2.5"
  }
}
